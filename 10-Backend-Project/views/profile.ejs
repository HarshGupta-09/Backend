<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full p-5 min-h-screen bg-zinc-900 text-white">
        <div class="flex w-full justify-end">
              <a  class="bg-red-500 mb-5 inline-block text-sm rounded-md px-3 py-2" href="/logout">
            Logout
        </a>
        </div>
     
<div class="flex gap-2">
   <div class="w-10 h-10  rounded-full">
    <img class="w-full h-full object-cover" src="image/uploads/<%=user.profilePic%>"   alt =""> </div>
     <h3 class="mb-2 text-3xl">
            <span class="font-light">Hello,</span> <%= user.name %>
        </h3>
</div>


     
      
        <h5 class="text-[#2196F3] mt-3 mb-5">You can create a new post</h5>

        <form action="/post" method="post">
              <textarea placeholder="what's on your mind ??" class="block outline-none text-white p-3 w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content">
     
        </textarea>
          <input class="px-3 block mt-2 cursor-pointer rounded-md py-2 bg-blue-500" type="submit" value="Create new post">
        </form>
      <div class="mt-20">
        <h3 class="text-zinc-400">YOUR POSTS</h3>
            <div class="postContianer mt-5">
               
              <% user.posts.reverse().forEach((post)=>{ %>
                 <div class="post mb-4 rounded-md w-1/3 p-5 border-[1px] border-zinc-700 bg-zinc-800">   
                    <h4 class="mb-2 text-blue-500">@<%=user.name%></h4>
                    <p class="text-sm"><%= post.content%></p>
                    <small class="mt-2 inline-block"><%= post.likes.length%> Like</small>
                    <div class="flex mt-1 gap-4">
                        <a class="text-blue-500" href="/like/<%=post._id %>"><%= post.likes.indexOf(user._id) != -1 ? "Unlike" : "like"  %></a>
                        <a class="text-zinc-300" href="/edit/<%= post._id %>">Edit</a>

                    </div>
                </div>
                <% }) %>
         
                 
            </div>
      </div>
     
    </div>
</body>

</html>