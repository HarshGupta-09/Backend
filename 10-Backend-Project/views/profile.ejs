<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full p-5 min-h-screen bg-zinc-900 text-white">
        <div class="flex w-full justify-end">
              <a  class="bg-red-500 mb-5 inline-block text-sm rounded-md px-3 py-2" href="/logout">
            Logout
        </a>
        </div>
      
        <h3 class="mb-2 text-3xl">
            <span class="font-light">Hello,</span> <%= user.name %>
        </h3>
        <h5 class="text-[#2196F3] mb-5">You can create a new post</h5>

        <form action="/post" method="post">
              <textarea placeholder="what's on your mind ??" class="block outline-none text-white p-3 w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content">
     
        </textarea>
          <input class="px-3 block mt-2 cursor-pointer rounded-md py-2 bg-blue-500" type="submit" value="Create new post">
        </form>
      <div class="mt-20">
        <h3 class="text-zinc-400">YOUR POSTS</h3>
            <div class="postContianer mt-5">
               
 <div class="post mb-4 rounded-md w-1/3 p-5 border-[1px]border-zinc-700 bg-zinc-800">   
                    <h4 class="mb-2 text-blue-500">@<%=user.name%></h4>
                    <p class="text-sm">Lorem ipsum dolor sit amet consectetur adipisicing elit. Doloribus corporis ut quaerat ipsa?</p>
                    <div class="flex mt-5 gap-4">
                        <a class="text-blue-500" href="">Like</a>
