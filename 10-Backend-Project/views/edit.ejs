<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full p-5 min-h-screen bg-zinc-900 text-white">
        <div class="flex w-full justify-end">
              <a  class="bg-red-500 mb-5 inline-block text-sm rounded-md px-3 py-2" href="/logout">
            Logout
        </a>
        </div>
      
       
        <h5 class="text-[#2196F3] mb-5">You can Edit your post Here</h5>

        <form action="/update/<%= post._id %>" method="post">
              <textarea placeholder="what's on your mind ??" class="block outline-none text-white p-3 w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content"><%= post.content %>
     
        </textarea>
          <input class="px-3 block mt-2 cursor-pointer rounded-md py-2 bg-yellow-600" type="submit" value="Update  post">
        </form>
     
     
    </div>
</body>

</html>