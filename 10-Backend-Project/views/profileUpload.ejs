<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full p-5 min-h-screen bg-zinc-900 text-white">
        <h3 class="mb-5 text-3xl">
            Upload Profile Picture
        </h3>
        <form action="/upload" method="POST" enctype="multipart/form-data">

            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-zinc-800" type="file" placeholder="email" name="image">
             <input class="px-3 block mt-2 cursor-pointer rounded-md py-2 bg-blue-500" type="submit" value="upload File">
        </form>
    </div>
</body>

</html>